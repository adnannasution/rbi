# Database - Railway akan otomatis set DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Atau bisa pakai individual vars (Railway set otomatis jika pakai PostgreSQL plugin)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rbi_app
DB_USER=rbi_admin
DB_PASS=secure_password

# JWT - WAJIB diganti di production!
JWT_SECRET=ganti-dengan-random-string-yang-panjang-dan-aman

# Server
PORT=3001
NODE_ENV=production
